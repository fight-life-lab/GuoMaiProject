{
    "schedule_time": "00:00",
    "time_range_mode": "fixed_day",
    "prometheus": {
        "url": "http://prometheus:9090",
        "extra_label_filters": {}
    },
    "output": {
        "prov_id": "省份编号",
        "data_type": "token_info",
        "protocol": "0",
        "local_data_dir": "./data_files"
    },
    "sftp": {
        "enabled": true,
        "host": "192.168.1.100",
        "port": 22,
        "username": "upload_user",
        "password": "",
        "private_key_path": "",
        "remote_dir": "/data/upload/token_info",
        "timeout": 30
    },
    "default_engine": "vllm",
    "metrics_presets": {
        "vllm": {
            "request_total": "vllm:request_success_total",
            "request_success": "vllm:request_success_total",
            "tokens_total": "vllm:prompt_tokens_total",
            "generation_tokens": "vllm:generation_tokens_total",
            "model_label": "model_name"
        },
        "mindie": {
            "request_total": "request_received_total",
            "request_success": "request_success_total",
            "tokens_total": "prompt_tokens_total",
            "generation_tokens": "generation_tokens_total",
            "model_label": "model_name"
        },
        "others": {
            "request_total": "others_request_success_total",
            "request_success": "others_request_success_total",
            "tokens_total": "others_prompt_tokens_total",
            "generation_tokens": "others_generation_tokens_total",
            "model_label": "model_name"
        }
    },
    "metrics_optional": {
        "request_success": false,
        "generation_tokens": false
    },
